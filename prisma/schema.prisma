// JAYKAVI — site database schema
// Mirrors the existing songwriter_data.json structure.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------- SINGLETON CONFIG --------------------------

// Singleton: there is exactly one Lyricist row (the artist profile).
model Lyricist {
  id                         Int      @id @default(1)
  name                       String
  penName                    String?
  displayName                String?
  creditVariants             String[] @default([])
  title                      String?
  tagline                    String
  bornPlace                  String?
  basedIn                    String?
  birthDate                  String?
  languages                  String[] @default([])
  genres                     String[] @default([])
  careerStartYear            Int?
  songsWritten               String?
  songsPublishedOnStreaming  String?
  bio                        String
  philosophy                 String?
  awards                     String[] @default([])
  press                      String[] @default([])
  updatedAt                  DateTime @updatedAt
}

// Singleton: there is exactly one Contact row.
model Contact {
  id                  Int      @id @default(1)
  useContactForm      Boolean  @default(true)
  showEmailPublicly   Boolean  @default(false)
  instagram           String?
  instagramSecondary  String?
  youtube             String?
  spotify             String?
  jiosaavn            String?
  privateEmail        String?
  privatePhone        String?
  privateNote         String?
  updatedAt           DateTime @updatedAt
}

// ------------------------------ CONTENT ------------------------------

model Singer {
  id        String   @id @default(cuid())
  legacyId  String?  @unique
  name      String
  photoUrl  String?
  bio       String?
  sortOrder Int      @default(0)
  songs     SongSinger[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Collection {
  id          String   @id @default(cuid())
  legacyId    String?  @unique
  slug        String   @unique
  title       String
  description String
  coverUrl    String?
  year        Int?
  songs       Song[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Song {
  id                 String              @id @default(cuid())
  legacyId           String?             @unique
  slug               String              @unique
  title              String
  subtitle           String?             // editable secondary line (cleaned/readable title)
  altTitles          String[]            @default([])
  lyricistCredit     String
  composer           String?
  collectionId       String?
  collection         Collection?         @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  language           String
  genre              String[]            @default([])
  mood               String[]            @default([])
  releaseYear        Int?
  artworkUrl         String?
  lyrics             String              @default("")
  viewCount          Int                 @default(0)
  pageViews          Int                 @default(0) // on-site reads (privacy-friendly counter)
  isTrending         Boolean             @default(false)
  youtubeId          String?
  spotifyTrackId     String?
  platformLinks      PlatformLink[]
  lyricsTranslations LyricsTranslation[]
  singers            SongSinger[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

// Join table: a Song has many performing Singers.
model SongSinger {
  songId   String
  singerId String
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  singer   Singer @relation(fields: [singerId], references: [id], onDelete: Cascade)

  @@id([songId, singerId])
}

model PlatformLink {
  id        String  @id @default(cuid())
  songId    String
  song      Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  isPrimary Boolean @default(false)
}

model LyricsTranslation {
  id       String @id @default(cuid())
  songId   String
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  language String
  text     String
}

model JourneyMilestone {
  id             String   @id @default(cuid())
  legacyId       String?  @unique
  year           Int?
  title          String
  description    String
  imageUrl       String?
  relatedSongIds String[] @default([])
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Blog / updates posts shown publicly at /blog.
model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    @default("")
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

// ----------------------------- HARVESTER -----------------------------

// Singleton: harvester configuration (editable from admin UI).
model HarvestConfig {
  id                Int      @id @default(1)
  ownChannels       String[] @default([])
  searchChannels    String[] @default([])
  searchTerms       String[] @default([])
  creditMustContain String[] @default([])
  knownSingers      String[] @default([])
  maxResultsPerTerm Int      @default(100)
  autoRun           Boolean  @default(false) // weekly auto-harvest on/off
  updatedAt         DateTime @updatedAt
}

// One row per harvest run.
model HarvestRun {
  id         String             @id @default(cuid())
  startedAt  DateTime           @default(now())
  finishedAt DateTime?
  status     String             @default("running") // running | done | error
  scanned    Int                @default(0)
  newFound   Int                @default(0)
  approved   Int                @default(0)
  errorMsg   String?
  candidates HarvestCandidate[]
}

// Each YouTube video surfaced by a run — awaiting admin review.
model HarvestCandidate {
  id           String     @id @default(cuid())
  runId        String
  run          HarvestRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  youtubeId    String
  rawTitle     String
  cleanTitle   String
  channelTitle String?
  description  String     @default("")
  thumbnailUrl String?
  viewCount    Int?
  releaseYear  Int?
  singerGuess  String?
  status       String     @default("pending") // pending | approved | rejected | duplicate
  songId       String?    // set when approved -> links to created Song
  createdAt    DateTime   @default(now())

  @@unique([youtubeId]) // one candidate per video, ever
}

// ------------------------------- ADMINS ---------------------------------

// Admin users manageable from the admin panel.
// The emails listed in the ADMIN_EMAILS env var are always admins too
// (permanent owners that cannot be removed from the UI).
model AdminUser {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        String   @default("Admin")
  note        String?
  permissions String[] @default([]) // section keys this admin may edit; see lib/permissions.ts
  // Personal profile fields each admin can edit themselves
  title       String? // job title / designation
  phone       String?
  photoUrl    String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------- ACTIVITY LOG -----------------------------

// Audit trail of admin sign-ins and content changes.
model ActivityLog {
  id         String   @id @default(cuid())
  actorEmail String? // who did it
  action     String // login | create | update | delete
  entity     String // Song | Singer | Admin | Config | Auth | ...
  label      String? // human-readable name of the affected item
  detail     String? // optional extra context
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ----------------------------- ANALYTICS --------------------------------

// One row per calendar day: total on-site song views that day.
// Bounded + tiny (one row/day). Pruned to ~90 days by the cron job.
model DailyView {
  day   String @id // YYYY-MM-DD
  count Int    @default(0)
}

// ------------------------------- BACKUP ---------------------------------

// Singleton: the latest full-content backup, overwritten on every run
// (weekly via cron, or manually from the admin panel). Stored as JSON text
// so it stays a single, bounded row.
model Backup {
  id        Int      @id @default(1)
  data      String // JSON snapshot of all content
  itemCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------- SITE SETTINGS ----------------------------

// Singleton: global appearance settings.
// activeTheme: which visual skin is shown to all visitors.
// "default" = the original JAYKAVI cinematic skin.
// Future skins just add a new CSS block + a new string value here.
model SiteSettings {
  id                Int     @id @default(1)
  activeTheme       String  @default("default")
  // Traditional theme customization (all have safe defaults so existing rows work)
  tradMantra        String  @default("॥ જય શ્રી કૃષ્ણ ॥")
  tradHeroPortrait  String? // left hero arch — singer portrait URL
  tradHeroDeity     String? // right hero arch — deity image URL
  tradHeroBg        String? // optional full-bleed hero background image
  tradHeroBgVideo   String? // optional full-bleed hero background video
  tradF1Title       String  @default("ભક્તિ")
  tradF1Desc        String  @default("શુદ્ધ ભાવ અને શ્રદ્ધા")
  tradF2Title       String  @default("સંગીત")
  tradF2Desc        String  @default("સુરોથી સર્જાયેલ ભક્તિ")
  tradF3Title       String  @default("સંસ્કૃતિ")
  tradF3Desc        String  @default("ગુજરાતી સંસ્કૃતિનો સંગમ")
  tradF4Title       String   @default("સેવા")
  tradF4Desc        String   @default("સંગીત દ્વારા સેવા અને સમર્પણ")

  // Heritage Library theme customization (all optional / defaulted)
  herHeroPhoto      String?  // grand artist banner photo
  herHeroVideo      String?  // optional hero background video
  herEyebrow        String   @default("Digital Heritage Library")
  herTitle          String   @default("Jayesh Prajapati")
  herSubtitle       String   @default("A living archive of Gujarati verse, bhajan and lyric.")
  herQuote          String?  // featured literary quote
  herStatsJson      String?  // JSON array of { value, label } shown in the stat strip
  herAboutPhoto     String?  // small portrait shown in the About card
  herAboutBody      String?  // About-section paragraph (overrides bio)
  herAudioTitle     String?  // vintage player heading
  herAudioTrack     String?  // featured track title in the player
  herFooterQuote    String?  // closing devotional quote line
  herGallery        String[] @default([]) // gallery image URLs
  herEventsJson     String?  // JSON array of { date, title, place }
  herLegacyTitle    String   @default("The Legacy")
  herLegacyBody     String?  // legacy paragraph
  herShowStats      Boolean  @default(true)
  herShowBhajans    Boolean  @default(true)
  herShowPoetry     Boolean  @default(true)
  herShowAudio      Boolean  @default(true)
  herShowVideos     Boolean  @default(true)
  herShowGallery    Boolean  @default(true)
  herShowEvents     Boolean  @default(true)
  herShowLegacy     Boolean  @default(true)

  viewsSyncedAt     DateTime? // last time YouTube view counts were refreshed
}

// ----------------------------- NOTEBOOK --------------------------------

// Folders to organise notes / song drafts.
model NoteFolder {
  id        String   @id @default(cuid())
  title     String
  sortOrder Int      @default(0)
  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A note/draft written by the admin (typically the lyricist).
model Note {
  id          String      @id @default(cuid())
  title       String      @default("Untitled")
  content     String      @default("")
  published   Boolean     @default(false)
  publishedAt DateTime?
  pinned      Boolean     @default(false)
  tags        String[]    @default([])
  folderId    String?
  folder      NoteFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([published])
  @@index([folderId])
  @@index([pinned])
}

// ----------------------------- CONTACT MESSAGES -------------------------

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
