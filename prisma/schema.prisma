// JAYKAVI — site database schema
// Mirrors the existing songwriter_data.json structure.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------- SINGLETON CONFIG --------------------------

// Singleton: there is exactly one Lyricist row (the artist profile).
model Lyricist {
  id                         Int      @id @default(1)
  name                       String
  penName                    String?
  displayName                String?
  creditVariants             String[] @default([])
  title                      String?
  tagline                    String
  bornPlace                  String?
  basedIn                    String?
  birthDate                  String?
  languages                  String[] @default([])
  genres                     String[] @default([])
  careerStartYear            Int?
  songsWritten               String?
  songsPublishedOnStreaming  String?
  bio                        String
  philosophy                 String?
  awards                     String[] @default([])
  press                      String[] @default([])
  updatedAt                  DateTime @updatedAt
}

// Singleton: there is exactly one Contact row.
model Contact {
  id                  Int      @id @default(1)
  useContactForm      Boolean  @default(true)
  showEmailPublicly   Boolean  @default(false)
  instagram           String?
  instagramSecondary  String?
  youtube             String?
  spotify             String?
  jiosaavn            String?
  privateEmail        String?
  privatePhone        String?
  privateNote         String?
  updatedAt           DateTime @updatedAt
}

// ------------------------------ CONTENT ------------------------------

model Singer {
  id        String   @id @default(cuid())
  legacyId  String?  @unique
  name      String
  photoUrl  String?
  bio       String?
  sortOrder Int      @default(0)
  songs     SongSinger[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Collection {
  id          String   @id @default(cuid())
  legacyId    String?  @unique
  slug        String   @unique
  title       String
  description String
  coverUrl    String?
  year        Int?
  songs       Song[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Song {
  id                 String              @id @default(cuid())
  legacyId           String?             @unique
  slug               String              @unique
  title              String
  altTitles          String[]            @default([])
  lyricistCredit     String
  composer           String?
  collectionId       String?
  collection         Collection?         @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  language           String
  genre              String[]            @default([])
  mood               String[]            @default([])
  releaseYear        Int?
  artworkUrl         String?
  lyrics             String              @default("")
  viewCount          Int                 @default(0)
  isTrending         Boolean             @default(false)
  youtubeId          String?
  spotifyTrackId     String?
  platformLinks      PlatformLink[]
  lyricsTranslations LyricsTranslation[]
  singers            SongSinger[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

// Join table: a Song has many performing Singers.
model SongSinger {
  songId   String
  singerId String
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  singer   Singer @relation(fields: [singerId], references: [id], onDelete: Cascade)

  @@id([songId, singerId])
}

model PlatformLink {
  id        String  @id @default(cuid())
  songId    String
  song      Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  isPrimary Boolean @default(false)
}

model LyricsTranslation {
  id       String @id @default(cuid())
  songId   String
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  language String
  text     String
}

model JourneyMilestone {
  id             String   @id @default(cuid())
  legacyId       String?  @unique
  year           Int?
  title          String
  description    String
  imageUrl       String?
  relatedSongIds String[] @default([])
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ----------------------------- HARVESTER -----------------------------

// Singleton: harvester configuration (editable from admin UI).
model HarvestConfig {
  id                Int      @id @default(1)
  ownChannels       String[] @default([])
  searchChannels    String[] @default([])
  searchTerms       String[] @default([])
  creditMustContain String[] @default([])
  knownSingers      String[] @default([])
  maxResultsPerTerm Int      @default(100)
  updatedAt         DateTime @updatedAt
}

// One row per harvest run.
model HarvestRun {
  id         String             @id @default(cuid())
  startedAt  DateTime           @default(now())
  finishedAt DateTime?
  status     String             @default("running") // running | done | error
  scanned    Int                @default(0)
  newFound   Int                @default(0)
  approved   Int                @default(0)
  errorMsg   String?
  candidates HarvestCandidate[]
}

// Each YouTube video surfaced by a run — awaiting admin review.
model HarvestCandidate {
  id           String     @id @default(cuid())
  runId        String
  run          HarvestRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  youtubeId    String
  rawTitle     String
  cleanTitle   String
  channelTitle String?
  description  String     @default("")
  thumbnailUrl String?
  viewCount    Int?
  releaseYear  Int?
  singerGuess  String?
  status       String     @default("pending") // pending | approved | rejected | duplicate
  songId       String?    // set when approved -> links to created Song
  createdAt    DateTime   @default(now())

  @@unique([youtubeId]) // one candidate per video, ever
}

// ------------------------------- ADMINS ---------------------------------

// Admin users manageable from the admin panel.
// The emails listed in the ADMIN_EMAILS env var are always admins too
// (permanent owners that cannot be removed from the UI).
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("Admin")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------- CONTACT MESSAGES -------------------------

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
