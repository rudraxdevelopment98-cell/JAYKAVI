# --- Database (Postgres) ---
# Use Neon, Supabase, or Railway. Free tier works.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Used in production; leave blank locally (auto-detects).
AUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Admin allowlist ---
# Comma-separated list of emails allowed into /admin.
ADMIN_EMAILS="owner@example.com"

# --- YouTube Data API (for Song Harvester) ---
# Free quota: 10,000 units/day. Get a key at:
# https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=""

# --- Cloudinary ---
# Sign up at https://cloudinary.com — free tier is generous.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- SEO ---
# Your live domain (no trailing slash). Used for canonical URLs and sitemap.
# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Google Search Console ownership verification code.
# Get it from: https://search.google.com/search-console → Add property → HTML tag method
# Copy ONLY the content="..." value (e.g. "abc123xyz")
GOOGLE_SITE_VERIFICATION=""
